NODE_ENV=development
LISTEN_PORT=8080

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=codex_switch
POSTGRES_PASSWORD=codex_switch
POSTGRES_DB=codex_switch
POSTGRES_DB_SYNCHRONIZE=true

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# SMTP email verification. Mailgun SMTP example:
mail__transport=SMTP
mail__options__host=smtp.mailgun.org
mail__options__port=465
mail__options__secure=true
mail__options__auth__user=
mail__options__auth__pass=
mail__from="Codex Switch <noreply@example.com>"

JWT_ACCESS_EXPIRES=15m
REFRESH_TOKEN_TTL_SECONDS=2592000
# Required in production. Generate with: openssl rand -hex 32
JWT_REFRESH_SECRET=

# Kong JWT plugin maps the access token iss claim to a Consumer JWT credential key.
KONG_JWT_KEY=codex-switch
# Required in production and must match the Kong JWT credential secret.
KONG_JWT_SECRET=

# Optional Codex OAuth overrides. The defaults match the official Codex CLI device flow.
CODEX_OAUTH_CLIENT_ID=
CODEX_OAUTH_ISSUER=https://auth.openai.com
